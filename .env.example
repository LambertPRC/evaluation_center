DB_POOL_RECYCLE=1800
DB_CONNECT_TIMEOUT=5
DB_READY_TIMEOUT=3
DB_ECHO=false

HTTP_TIMEOUT=10
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20
HTTP_KEEPALIVE_EXPIRY=5
